# Run from the dev/ directory.
#
# The stack self-installs on first `docker compose up`; the recipes
# below are just shortcuts. `just` on its own lists everything.

dc  := "docker compose"
php := dc + " exec -T phpfpm"

# Show available recipes.
default:
    @just --list --unsorted

# Bring up the stack and wait for it to be healthy. First run installs Magento (~10 min).
up:
    {{dc}} up -d --wait

# Stop the stack (keep data).
down:
    {{dc}} down

# Stop and delete all volumes.
destroy:
    {{dc}} down -v

# Tail container logs.
logs:
    {{dc}} logs -f

# Show container status.
ps:
    {{dc}} ps

# Open a shell in the phpfpm container.
shell:
    {{dc}} exec phpfpm bash

# Deploy Magento sample data (slow, ~10-15 min).
sample-data:
    {{php}} bin/magento sampledata:deploy
    {{php}} bin/magento setup:upgrade
    {{php}} bin/magento cache:flush

# Run bin/magento <args> inside the container, e.g. `just magento cache:flush`.
magento *args:
    {{php}} bin/magento {{args}}
