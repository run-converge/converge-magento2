#!/usr/bin/env bash
# Thin wrapper: run bin/magento against the scaffolded Magento install.
#
#   mage cache:flush
#   mage setup:upgrade
#   mage module:status Converge_Converge
#
set -euo pipefail

: "${REPO_ROOT:?run from inside the flox env (flox activate)}"
: "${MAGENTO_ROOT:?run from inside the flox env (flox activate)}"

if [ ! -x "$MAGENTO_ROOT/bin/magento" ]; then
  echo "error: $MAGENTO_ROOT/bin/magento not found — run 'mage-bootstrap' first" >&2
  exit 1
fi

cd "$MAGENTO_ROOT"
exec php -d memory_limit="${PHP_MEMORY_LIMIT:-4G}" bin/magento "$@"
